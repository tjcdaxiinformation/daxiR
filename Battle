<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3 vs 3 默契對抗計分板</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&family=Noto+Sans+TC:wght@400;700;900&display=swap');
        
        body {
            background-color: #020617;
            font-family: 'Noto Sans TC', sans-serif;
            color: white;
            overflow: hidden;
        }

        .excel-cell {
            border: 1px solid #1e293b;
            transition: all 0.2s;
        }

        .excel-cell:focus-within {
            background-color: #0f172a;
            border-color: #3b82f6;
            box-shadow: inset 0 0 10px rgba(59, 130, 246, 0.2);
        }

        .team-a-theme { border-left: 8px solid #ef4444; }
        .team-b-theme { border-left: 8px solid #3b82f6; }

        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .score-btn {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .score-btn:active {
            transform: scale(0.9);
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo } = React;

        const STAGES = ['默契題 1', '默契題 2', '默契題 3', '默契題 4', '其他挑戰'];
        
        const INITIAL_TEAMS = [
            { 
                id: 'A', 
                name: '紅隊 (A)', 
                members: ['學員 1', '學員 2', '學員 3'],
                scores: [0, 0, 0, 0, 0]
            },
            { 
                id: 'B', 
                name: '藍隊 (B)', 
                members: ['學員 4', '學員 5', '學員 6'],
                scores: [0, 0, 0, 0, 0]
            }
        ];

        function App() {
            const [teams, setTeams] = useState(INITIAL_TEAMS);

            const processedTeams = useMemo(() => {
                return teams.map(t => ({
                    ...t,
                    total: t.scores.reduce((a, b) => a + b, 0)
                }));
            }, [teams]);

            const updateScore = (teamId, stageIdx, value) => {
                setTeams(prev => prev.map(t => {
                    if (t.id === teamId) {
                        const newScores = [...t.scores];
                        newScores[stageIdx] = parseInt(value) || 0;
                        return { ...t, scores: newScores };
                    }
                    return t;
                }));
            };

            const addTacitScore = (teamId, stageIdx, points) => {
                setTeams(prev => prev.map(t => {
                    if (t.id === teamId) {
                        const newScores = [...t.scores];
                        newScores[stageIdx] = points;
                        return { ...t, scores: newScores };
                    }
                    return t;
                }));
            };

            const updateInfo = (teamId, field, value, memberIdx = null) => {
                setTeams(prev => prev.map(t => {
                    if (t.id === teamId) {
                        if (field === 'name') return { ...t, name: value };
                        if (field === 'member') {
                            const newMembers = [...t.members];
                            newMembers[memberIdx] = value;
                            return { ...t, members: newMembers };
                        }
                    }
                    return t;
                }));
            };

            return (
                <div className="h-screen w-screen flex flex-col p-6 gap-6">
                    {/* Header */}
                    <div className="flex justify-between items-center px-4">
                        <div className="space-y-1">
                            <h1 className="text-5xl font-black italic tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-red-500 to-blue-500">
                                3 VS 3 TACIT BATTLE
                            </h1>
                            <p className="text-slate-500 font-mono text-sm tracking-[0.3em]">CELL GROUP CONFRONTATION MODE</p>
                        </div>
                        <div className="flex items-center gap-8">
                            <div className="text-center">
                                <div className="text-slate-500 text-xs font-bold uppercase mb-1">對抗狀態</div>
                                <div className="flex items-center gap-2 text-yellow-500 font-black text-xl italic">
                                    <span className="w-3 h-3 bg-yellow-500 rounded-full animate-ping"></span>
                                    BATTLE LIVE
                                </div>
                            </div>
                        </div>
                    </div>

                    {/* Main Scoreboard Area */}
                    <div className="flex-1 grid grid-cols-2 gap-8">
                        {processedTeams.map((team) => (
                            <div key={team.id} className={`flex flex-col bg-slate-900/40 rounded-[2rem] border border-slate-800 overflow-hidden ${team.id === 'A' ? 'team-a-theme' : 'team-b-theme'}`}>
                                {/* Team Header */}
                                <div className="p-8 bg-slate-900/60 border-b border-slate-800 flex justify-between items-center">
                                    <div className="space-y-4 flex-1">
                                        <input 
                                            type="text" 
                                            value={team.name}
                                            onChange={(e) => updateInfo(team.id, 'name', e.target.value)}
                                            className="bg-transparent text-5xl font-black outline-none w-full border-b-2 border-dashed border-slate-700 focus:border-white transition-colors"
                                        />
                                        <div className="flex gap-4">
                                            {team.members.map((m, mIdx) => (
                                                <input 
                                                    key={mIdx}
                                                    type="text" 
                                                    value={m}
                                                    onChange={(e) => updateInfo(team.id, 'member', e.target.value, mIdx)}
                                                    className="bg-slate-800 px-3 py-1 rounded-lg text-sm font-bold text-slate-400 outline-none focus:text-white"
                                                />
                                            ))}
                                        </div>
                                    </div>
                                    <div className="text-right pl-8">
                                        <div className="text-slate-500 text-xs font-black uppercase tracking-widest mb-1">Group Total</div>
                                        <div className={`text-9xl font-black italic tracking-tighter ${team.id === 'A' ? 'text-red-500' : 'text-blue-500'}`}>
                                            {team.total}
                                        </div>
                                    </div>
                                </div>

                                {/* Scoring Grid */}
                                <div className="flex-1 p-8 overflow-y-auto custom-scrollbar">
                                    <table className="w-full">
                                        <thead>
                                            <tr className="text-slate-500 text-xs font-black uppercase tracking-widest text-left">
                                                <th className="pb-4">挑戰項目</th>
                                                <th className="pb-4 text-center">手動輸入</th>
                                                <th className="pb-4 text-right">默契給分 (2/3 或 3/3)</th>
                                            </tr>
                                        </thead>
                                        <tbody className="space-y-4">
                                            {STAGES.map((s, sIdx) => (
                                                <tr key={sIdx} className="group">
                                                    <td className="py-3 text-xl font-bold text-slate-300">{s}</td>
                                                    <td className="py-3 px-4">
                                                        <div className="excel-cell rounded-xl overflow-hidden bg-slate-950/50">
                                                            <input 
                                                                type="number" 
                                                                value={team.scores[sIdx] || ''}
                                                                placeholder="0"
                                                                onChange={(e) => updateScore(team.id, sIdx, e.target.value)}
                                                                className="w-full h-full bg-transparent p-3 text-2xl font-black text-center outline-none text-white focus:text-blue-400"
                                                            />
                                                        </div>
                                                    </td>
                                                    <td className="py-3 text-right space-x-2">
                                                        <button 
                                                            onClick={() => addTacitScore(team.id, sIdx, 50)}
                                                            className={`score-btn px-4 py-2 rounded-xl text-sm font-black border-2 ${team.scores[sIdx] === 50 ? 'bg-yellow-500 border-yellow-500 text-slate-950 shadow-[0_0_15px_rgba(234,179,8,0.4)]' : 'border-slate-800 text-slate-500 hover:border-yellow-500/50 hover:text-yellow-500'}`}
                                                        >
                                                            及格 +50
                                                        </button>
                                                        <button 
                                                            onClick={() => addTacitScore(team.id, sIdx, 150)}
                                                            className={`score-btn px-4 py-2 rounded-xl text-sm font-black border-2 ${team.scores[sIdx] === 150 ? 'bg-green-500 border-green-500 text-slate-950 shadow-[0_0_15px_rgba(34,197,94,0.4)]' : 'border-slate-800 text-slate-500 hover:border-green-500/50 hover:text-green-500'}`}
                                                        >
                                                            完勝 +150
                                                        </button>
                                                    </td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        ))}
                    </div>

                    {/* Rules Footer Overlay */}
                    <div className="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex justify-between items-center">
                        <div className="flex gap-10">
                            <div className="flex items-center gap-3">
                                <span className="px-3 py-1 bg-yellow-500/10 text-yellow-500 border border-yellow-500/30 rounded font-black">及格 50分</span>
                                <span className="text-slate-400 text-sm font-bold">2/3 答案一致 (66% 默契)</span>
                            </div>
                            <div className="flex items-center gap-3">
                                <span className="px-3 py-1 bg-green-500/10 text-green-500 border border-green-500/30 rounded font-black">完勝 150分</span>
                                <span className="text-slate-400 text-sm font-bold">3/3 全員一致 (100% 完勝)</span>
                            </div>
                        </div>
                        <div className="text-slate-600 font-mono text-xs italic">
                            PROJECTION READY • {new Date().toLocaleTimeString()}
                        </div>
                    </div>

                    <style dangerouslySetInnerHTML={{ __html: `
                        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
                        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
                        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
                    `}} />
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
